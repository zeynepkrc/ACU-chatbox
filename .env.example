# Copy to .env in the project root and adjust before production.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web,0.0.0.0
DJANGO_PORT=8000

# Yerelde yalnızca ``python manage.py runserver`` (Docker web yok): ``docker compose up db ollama`` yeterli.
# Varsayılan ayarlar 127.0.0.1:5433 (compose yayın portu) ve 127.0.0.1:11434 kullanır.
# Yerel Postgres 5432 kullanıyorsanız: DATABASE_PORT=5432

POSTGRES_USER=acu
POSTGRES_PASSWORD=acu
POSTGRES_DB=acu_chatbot
# Host port mapped to Postgres (avoids clashing with a local Postgres on 5432).
POSTGRES_PUBLISH_PORT=5433

# Ollama (Docker service name: ollama). İlk açılışta model çekilir (CPU'da uzun sürebilir).
# Güçlü GPU/CPU için: OLLAMA_MODEL=qwen2.5:14b
OLLAMA_START_MODEL=qwen2.5:7b
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://ollama:11434
# HTTP: bağlantı (s) ve toplam okuma süresi üst sınırı (s). Qwen gibi modeller için okuma süresini yükseltin.
OLLAMA_REQUEST_CONNECT_SEC=45
OLLAMA_REQUEST_TIMEOUT_SEC=3600
# RAG: Ollama'ya en fazla kaç UniversityContent parçası (önerilen 3).
RAG_CONTEXT_MAX_DOCUMENTS=3
OLLAMA_HOST_PORT=11434
